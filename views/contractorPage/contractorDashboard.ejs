<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Listings</title>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@700&display=swap" rel="stylesheet"> 
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <link rel="stylesheet" href="/sellerStyle.css" />
    <link rel="icon" href="https://res.cloudinary.com/datlajath/image/upload/v1729872176/AgroGuide/p5f3ij1zqjipsifdj0mt.png">
</head>
<body>
    <nav class="navbar bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="javascript:history.back()">
                <img src="https://res.cloudinary.com/datlajath/image/upload/v1729872176/AgroGuide/p5f3ij1zqjipsifdj0mt.png" alt="Logo" width="30" height="30" class="d-inline-block align-text-top">
                <span style="color: green; font-weight: bold;">AgroGuide</span>
            </a>
            <div>
                <a href="/contractor/edit" class="btn btn-dark">Edit Profile</a> 
            </div>
        </div>
    </nav>

    <h1 class="text-center">Your Listings</h1> 

    <div class="text-center mb-3">
        <a href="/contract/new">
            <button class="btn btn-primary">Add new listing</button> 
        </a>
    </div>

    <div class="main-container d-flex flex-wrap justify-content">
        <% if (contracts.length > 0) { %>
            <% contracts.forEach(contract => { %>
                <div class="card m-2" style="width: 18rem; flex-direction: column;"> 
                    <div class="card-body">
                        <h5 class="card-title">Rent: <%= contract.rent %> <%= contract.rent_type %></h5>
                        <p class="card-text"><strong>Area:</strong> <%= contract.area %></p>
                        <p class="card-text"><%= contract.terms %></p>
                    </div>
                    <div class="card-footer text-right">
                        <a href="/contract/edit/<%= contract._id %>" class="btn btn-warning btn-sm">Edit</a>
                        <form action="/contract/delete/<%= contract._id %>" method="POST" style="display: inline;">
                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                        </form>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <p>No listings found. Please add a Contract.</p>
        <% } %>
    </div>

    <!-- Scripts -->
    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script> 
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.9.2/dist/umd/popper.min.js"></script> 
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script> 
</html>
